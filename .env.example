# Office Workplace Intelligence Platform — environment variables
# Copy this to Register_App/.env, Admin/.env, and Webcam/.env as needed.
# Do not commit .env files (they are in .gitignore).

# --- Common (all apps) ---
SECRET_KEY=your-secret-key-here

# --- Email (optional): leave all commented/blank to run WITHOUT email ---
# Apps will start and work; visitor/host/feedback emails are skipped.
# EMAIL_USER=rohankolachala@gmail.com
# EMAIL_PASS=your-app-password
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587

# --- Register_App ---
# GEMINI_API_KEY=...   # For chatbot (optional)
# GOOGLE_API_KEYS=...  # Used by chatbot_utils.py

# --- Admin ---
USE_MOCK_DATA=True
REGISTRATION_APP_URL=http://localhost:5001

# --- Webcam ---
AUTH_MODE=hybrid
COMPANY_IP=
USE_MOCK_DATA=False

# --- Firebase ---
# Place firebase_credentials.json in each app directory (Register_App, Admin, Webcam).
# Realtime Database console: https://console.firebase.google.com/u/0/project/visitor-management-8f5b4/database/visitor-management-8f5b4-default-rtdb/data/~2F
# Backend (Python) uses FIREBASE_DATABASE_URL. Frontend (e.g. dashboard) uses the client config below.
FIREBASE_DATABASE_URL=https://visitor-management-8f5b4-default-rtdb.firebaseio.com

# Firebase client config (for browser/JS; used by Webcam dashboard and any frontend that talks to Firebase)
FIREBASE_API_KEY=AIzaSyDQ1xKacawkZKz9n12PPJCwhUPIKuHmGqU
FIREBASE_AUTH_DOMAIN=visitor-management-8f5b4.firebaseapp.com
FIREBASE_PROJECT_ID=visitor-management-8f5b4
FIREBASE_STORAGE_BUCKET=visitor-management-8f5b4.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=160208135498
